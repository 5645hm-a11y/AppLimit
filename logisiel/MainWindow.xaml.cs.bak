using System;
using System.Windows;
using System.Windows.Controls;
using System.Windows.Media;
using System.Windows.Media.Animation;
using System.Threading.Tasks;
using System.Diagnostics;
using System.Threading;

namespace GrayscaleDesktopApp
{
    public partial class MainWindow : Window
    {
        private int currentStep = 0;
        private CancellationTokenSource cancellationToken = new CancellationTokenSource();

        public MainWindow()
        {
            InitializeComponent();
            Loaded += async (s, e) => await DisplaySplashScreen();
        }

        private async Task DisplaySplashScreen()
        {
            // Get splash screen elements
            var stackPanel = (StackPanel)SplashScreen.Children[0];
            var titleBlock = (TextBlock)stackPanel.Children[0];
            
            // Fade in and scale animation
            DoubleAnimation opacityAnim = new DoubleAnimation(0, 1, TimeSpan.FromMilliseconds(800));
            ScaleTransform scale = new ScaleTransform(0.8, 0.8);
            titleBlock.RenderTransform = scale;

            DoubleAnimation scaleAnim = new DoubleAnimation(0.8, 1, TimeSpan.FromMilliseconds(800));
            scaleAnim.EasingFunction = new QuadraticEase();

            titleBlock.BeginAnimation(OpacityProperty, opacityAnim);
            scale.ScaleX = 1;
            scale.ScaleY = 1;

            await Task.Delay(2500); // Show splash for 2.5 seconds
            
            // Fade out splash and show step 1
            FadeOutElement(SplashScreen);
            await Task.Delay(500);
            
            ShowStep(1);
        }

        private void ShowStep(int step)
        {
            currentStep = step;
            
            // Hide all steps
            Step1.Visibility = Visibility.Collapsed;
            Step2.Visibility = Visibility.Collapsed;
            Step3.Visibility = Visibility.Collapsed;
            Step4.Visibility = Visibility.Collapsed;
            SplashScreen.Visibility = Visibility.Collapsed;

            // Show current step with animation
            Grid currentGrid = step switch
            {
                1 => Step1,
                2 => Step2,
                3 => Step3,
                4 => Step4,
                _ => Step1
            };

            currentGrid.Visibility = Visibility.Visible;
            
            // Fade in animation
            FadeInElement(currentGrid);

            if (step == 2)
            {
                // Start device detection when entering step 2
                _ = DetectDevice();
            }
        }

        private void OnStep1Complete(object sender, RoutedEventArgs e)
        {
            ShowStep(2);
        }

        private void OnStep2Complete(object sender, RoutedEventArgs e)
        {
            ShowStep(3);
        }

        private void OnStep3Complete(object sender, RoutedEventArgs e)
        {
            Step3Button.IsEnabled = false;
            _ = ExecuteGrayscaleCommand();
        }

        private void OnStep4Complete(object sender, RoutedEventArgs e)
        {
            Application.Current.Shutdown();
        }

        private async Task DetectDevice()
        {
            try
            {
                // Run ADB device detection
                while (currentStep == 2 && !cancellationToken.Token.IsCancellationRequested)
                {
                    var result = ExecuteAdbCommand("devices");
                    
                    if (result.Contains("device") && !result.Contains("List of attached devices"))
                    {
                        // Device found!
                        CheckMark.BeginAnimation(OpacityProperty, new DoubleAnimation(0, 1, TimeSpan.FromMilliseconds(500)));
                        DeviceStatusText.Text = "Device Connected! ✓";
                        Step2Button.IsEnabled = true;
                        return;
                    }
                    
                    DeviceStatusText.Text = "Searching for device...";
                    await Task.Delay(1000);
                }
            }
            catch (Exception ex)
            {
                DeviceStatusText.Text = $"Error: {ex.Message}";
            }
        }

        private async Task ExecuteGrayscaleCommand()
        {
            try
            {
                // Simulate progress with actual ADB commands
                for (int i = 0; i <= 100; i += 10)
                {
                    ProgressBar.Value = i;
                    ProgressText.Text = $"{i}%";

                    if (i == 30)
                    {
                        // Enable accessibility display daltonizer
                        ExecuteAdbCommand("shell settings put secure accessibility_display_daltonizer_enabled 1");
                    }
                    else if (i == 60)
                    {
                        // Set to grayscale mode
                        ExecuteAdbCommand("shell settings put secure accessibility_display_daltonizer 0");
                    }
                    else if (i == 100)
                    {
                        // Complete
                        ShowStep(4);
                        return;
                    }

                    await Task.Delay(400);
                }
            }
            catch (Exception ex)
            {
                ProgressText.Text = $"Error: {ex.Message}";
            }
        }

        private string ExecuteAdbCommand(string command)
        {
            try
            {
                string adbPath = Environment.GetEnvironmentVariable("LOCALAPPDATA") + "\\Android\\Sdk\\platform-tools\\adb.exe";
                
                ProcessStartInfo psi = new ProcessStartInfo
                {
                    FileName = adbPath,
                    Arguments = command,
                    RedirectStandardOutput = true,
                    RedirectStandardError = true,
                    UseShellExecute = false,
                    CreateNoWindow = true
                };

                using (Process process = Process.Start(psi))
                {
                    string output = process.StandardOutput.ReadToEnd();
                    process.WaitForExit();
                    return output;
                }
            }
            catch (Exception ex)
            {
                throw new Exception($"ADB Error: {ex.Message}");
            }
        }

        private void FadeInElement(UIElement element)
        {
            DoubleAnimation anim = new DoubleAnimation(0, 1, TimeSpan.FromMilliseconds(500));
            anim.EasingFunction = new QuadraticEase();
            element.BeginAnimation(OpacityProperty, anim);
        }

        private void FadeOutElement(UIElement element)
        {
            DoubleAnimation anim = new DoubleAnimation(1, 0, TimeSpan.FromMilliseconds(500));
            anim.EasingFunction = new QuadraticEase();
            element.BeginAnimation(OpacityProperty, anim);
        }

        protected override void OnClosed(EventArgs e)
        {
            cancellationToken.Cancel();
            base.OnClosed(e);
        }
    }
}
