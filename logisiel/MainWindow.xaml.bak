<Window x:Class="GrayscaleDesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppLimit - Grayscale Controller" 
        Width="400" 
        Height="700"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource DarkBgBrush}"
        Foreground="{StaticResource TextBrush}"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">
    
    <Window.Resources>
    </Window.Resources>

    <Grid Background="{StaticResource DarkBgBrush}">
        <!-- Splash Screen -->
        <Grid x:Name="SplashScreen" Background="{StaticResource DarkBgBrush}" Panel.ZIndex="100">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="AppLimit" FontSize="64" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,20" Opacity="0">
                    <TextBlock.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
                <TextBlock Text="Grayscale Controller" FontSize="16" Foreground="{StaticResource TextBrush}" HorizontalAlignment="Center" Margin="0,0,0,20" Opacity="0"/>
                <ProgressBar Height="4" Width="150" Background="#FF444444" Foreground="{StaticResource PrimaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Phone Frame -->
        <Border x:Name="PhoneFrame" Background="{StaticResource DarkBg2Brush}" CornerRadius="40" BorderThickness="8" BorderBrush="#FF333333" Width="380" Height="680" HorizontalAlignment="Center" VerticalAlignment="Center" Panel.ZIndex="50">
            <Grid>
                <!-- Status bar -->
                <Border Height="30" VerticalAlignment="Top" Background="{StaticResource DarkBgBrush}">
                    <TextBlock Text="9:41" Foreground="{StaticResource TextBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Content Grid -->
                <Grid Margin="0,30,0,0">
                    <!-- Step 1 -->
                    <Grid x:Name="Step1" Visibility="Visible">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                            <TextBlock Text="📱" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="Enable Debug Mode" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Enable USB Debugging on your device" FontSize="14" Foreground="{StaticResource TextBrush}" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,20"/>
                            <Border Background="#FF333333" Height="120" CornerRadius="12" Margin="0,0,0,20">
                                <TextBlock Text="▶ Video Tutorial" FontSize="14" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button x:Name="Step1Button" Content="Continue" Style="{StaticResource PrimaryButtonStyle}" Click="OnStep1Complete"/>
                        </StackPanel>
                    </Grid>

                    <!-- Step 2 -->
                    <Grid x:Name="Step2" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                            <TextBlock Text="📱" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="Connect Device" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock x:Name="DeviceStatusText" Text="Waiting for device..." FontSize="14" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock x:Name="CheckMark" Text="✓" FontSize="48" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" Opacity="0" Margin="0,0,0,20"/>
                            <Button x:Name="Step2Button" Content="Continue" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False" Click="OnStep2Complete"/>
                        </StackPanel>
                    </Grid>

                    <!-- Step 3 -->
                    <Grid x:Name="Step3" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                            <TextBlock Text="📱" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="Enabling Grayscale" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,0,0,20"/>
                            <ProgressBar x:Name="ProgressBar" Height="6" Background="#FF333333" Foreground="{StaticResource PrimaryBrush}" Value="0" Margin="0,0,0,10"/>
                            <TextBlock x:Name="ProgressText" Text="0%" FontSize="14" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                            <Button x:Name="Step3Button" Content="Start" Style="{StaticResource PrimaryButtonStyle}" Click="OnStep3Complete"/>
                        </StackPanel>
                    </Grid>

                    <!-- Step 4 -->
                    <Grid x:Name="Step4" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                            <TextBlock Text="✓" FontSize="80" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                            <TextBlock Text="Success!" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,0,0,10"/>
                            <TextBlock Text="Grayscale enabled!" FontSize="14" Foreground="{StaticResource TextBrush}" TextAlignment="Center" Margin="0,0,0,30"/>
                            <Button x:Name="Step4Button" Content="Done" Style="{StaticResource PrimaryButtonStyle}" Click="OnStep4Complete"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
