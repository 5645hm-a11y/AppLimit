<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude encrypted PIN prefs — keys are device-bound, useless on other devices -->
        <exclude domain="sharedpref" path="secure_pin_prefs" />
        <!-- Exclude session / grace-period tokens -->
        <exclude domain="sharedpref" path="settings_protection" />
        <exclude domain="sharedpref" path="safetimeguard_security" />
        <!-- Exclude usage tracking state (device-local data) -->
        <exclude domain="sharedpref" path="usage_tracking_state" />
    </cloud-backup>
    <device-transfer>
        <!-- Allow rule transfer between devices, but not security state -->
        <exclude domain="sharedpref" path="secure_pin_prefs" />
        <exclude domain="sharedpref" path="settings_protection" />
        <exclude domain="sharedpref" path="usage_tracking_state" />
    </device-transfer>
</data-extraction-rules>
